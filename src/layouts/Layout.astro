---
import "~/styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import { siteLang, themeColor } from "~/data/config";

type Props = {
	title: string;
	pageTitle: string;
	description: string;
	/** Comma-separated; optional — limited use by Google, helps some tools */
	keywords?: string;
	/** Default index,follow */
	robots?: string;
	/** Schema.org JSON-LD (e.g. LocalBusiness on homepage) */
	jsonLd?: Record<string, unknown>;
};

const { pageTitle, title, description, keywords, robots, jsonLd } = Astro.props as Props;

const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const canonicalHref = new URL(Astro.url.pathname, siteOrigin).href;
const ogImageUrl = `${siteOrigin}/images/og-image.jpg`;
---

<!doctype html>
<html lang={siteLang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content={themeColor} />
		<meta name="description" content={description} />
		{keywords ? <meta name="keywords" content={keywords} /> : null}
		<meta name="robots" content={robots ?? "index, follow"} />
		<meta name="googlebot" content={robots ?? "index, follow"} />
		<link rel="canonical" href={canonicalHref} />
		<link rel="author" href="/humans.txt" />

		<meta name="msapplication-TileColor" content="#050505" />

		<meta property="og:url" content={canonicalHref} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:alt" content="Garage Cafe Rhodes — coffee and more" />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content="Garage Cafe Rhodes" />
		<meta property="og:locale" content={siteLang.replace("-", "_")} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalHref} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<title>{pageTitle}</title>
		{jsonLd ? <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} /> : null}
		<ClientRouter />
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
