---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Button from "~/components/Button.astro";
import { getLocalBusinessJsonLd, seoHome } from "~/data/seo";

const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
---

<Layout
	title={seoHome.ogTitle}
	pageTitle={seoHome.pageTitle}
	description={seoHome.description}
	keywords={seoHome.keywords}
	jsonLd={getLocalBusinessJsonLd(siteOrigin)}
>
	<!-- Full-screen hero: coffee background + overlay -->
	<Section
		contain={false}
		data-home-hero
		class:list={"relative min-h-[100dvh] h-[100dvh] w-full overflow-hidden"}
	>
		<div class="absolute inset-0" aria-hidden="true">
			<img
				data-home-hero-img
				src="/images/garage/hero-coffee.jpg"
				alt="Coffee at Garage Cafe, Rhodes"
				class="h-full w-full object-cover object-center will-change-transform"
				width="1920"
				height="1280"
				loading="eager"
				fetchpriority="high"
				decoding="async"
			/>
		</div>
		<div
			data-home-hero-overlay
			class="absolute inset-0 bg-gradient-to-b from-garage-black/80 via-garage-black/50 to-garage-black/85"
			aria-hidden="true"
		>
		</div>
		<div
			class="relative z-10 flex min-h-[100dvh] h-full flex-col justify-center px-4 pb-12 pt-[calc(var(--site-header-h)+0.5rem)] sm:px-6 lg:px-8"
		>
			<div class="container mx-auto max-w-3xl text-center">
				<p data-home-hero-animate class="font-garage text-sm tracking-[0.35em] text-garage-gold-muted uppercase mb-4">
					Rhodes
				</p>
				<h1
					data-home-hero-animate
					class="font-garage text-4xl sm:text-5xl lg:text-6xl text-garage-gold-bright leading-tight uppercase drop-shadow-sm"
				>
					Garage Cafe
				</h1>
				<div
					data-home-hero-line
					class="mx-auto my-6 h-px w-52 max-w-[80%] bg-gradient-to-r from-transparent via-garage-gold to-transparent"
					aria-hidden="true"
				>
				</div>
				<p
					data-home-hero-animate
					class="mt-2 text-xl sm:text-2xl font-bold text-[#e8dcc4] max-w-2xl mx-auto text-balance leading-snug"
				>
					Coffee and more — great coffee, a relaxed vibe, and flavour in the heart of Rhodes.
				</p>

				<div class="mt-10 [perspective:1200px] max-w-lg mx-auto">
					<div
						data-home-hero-offer
						class="p-6 sm:p-8 border border-garage-gold/35 rounded-2xl bg-garage-black/55 backdrop-blur-sm shadow-[0_0_60px_rgba(0,0,0,0.45)] [transform-style:preserve-3d] will-change-transform"
					>
						<p class="font-garage text-3xl sm:text-4xl text-garage-gold-bright tabular-nums">Only €4.80</p>
						<p class="mt-2 text-garage-gold-bright/95 font-medium">
							Coffee &amp; your choice of <span class="text-garage-gold">baguette</span>
						</p>
						<p class="mt-3 text-sm text-garage-gold-muted leading-relaxed">
							With butter, smoked turkey, cheese, tomato, and cucumber.
						</p>
					</div>
				</div>

				<div
					data-home-hero-animate
					class="mt-10 flex flex-col sm:flex-row gap-4 justify-center items-center"
				>
					<Button url="/menu">View menu</Button>
					<a
						href="/contact"
						class="not-prose inline-flex items-center justify-center rounded-full px-6 py-3 text-base font-semibold border border-garage-gold/50 text-garage-gold-bright hover:bg-garage-gold/10 transition-colors"
					>
						Contact
					</a>
				</div>
			</div>

			<div
				data-home-scroll-hint
				class="absolute bottom-2 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 hidden sm:flex"
			>
				<p class="text-xs text-garage-gold-muted/70 uppercase tracking-widest">Scroll</p>
				<span class="text-garage-gold/50" aria-hidden="true">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-6">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
					</svg>
				</span>
			</div>
		</div>
	</Section>

	<script>
		import "~/scripts/homeAnimations";
	</script>
</Layout>
