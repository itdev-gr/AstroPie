---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { siteLang, siteCurrency } from "~/data/config";
const plates = await getCollection("plates");
const siteLangFormat = siteLang.replace("_", "-");
---

<div class="max-w-6xl mx-auto lg:grid lg:grid-cols-[minmax(0,13rem)_minmax(0,1fr)] lg:gap-x-10 xl:gap-x-14 lg:items-start">
	<!-- Desktop: sticky rail -->
	<aside
		class="hidden lg:block sticky top-[calc(var(--site-header-h)+0.5rem)] z-[5] pb-8 rounded-xl border border-garage-gold/20 bg-garage-panel/55 p-4 shadow-[inset_0_1px_0_rgba(212,175,55,0.08)]"
	>
		<p class="font-garage text-[0.65rem] tracking-[0.28em] text-garage-gold-muted uppercase mb-5">On this page</p>
		<nav class="flex flex-col gap-0.5" aria-label="Menu sections">
			{
				plates.map((plate, i) => (
					<a
						href={`#${plate.data.slug}`}
						data-category-link={plate.data.slug}
						data-category-rail
						class="group flex items-center gap-3 py-2.5 pl-3 -ml-3 rounded-lg border-l-2 border-transparent text-garage-gold-muted hover:text-garage-gold-bright transition-colors"
					>
						<span class="font-mono text-[0.65rem] tabular-nums text-garage-gold-muted/60 group-hover:text-garage-gold/80">
							{String(i + 1).padStart(2, "0")}
						</span>
						<span class="text-sm font-medium tracking-wide">{plate.data.prettyName}</span>
					</a>
				))
			}
		</nav>
	</aside>

	<div class="min-w-0">
		<!-- Mobile / tablet: horizontal pills -->
		<div
			id="plate-nav-wrapper"
			class="mb-12 sticky top-[calc(var(--site-header-h)+0.5rem)] z-10 lg:hidden"
		>
			<nav
				class="border border-garage-gold/30 bg-garage-panel/95 backdrop-blur-md rounded-2xl shadow-[0_8px_40px_rgba(0,0,0,0.25),inset_0_1px_0_rgba(240,215,140,0.06)]"
				aria-label="Menu sections"
			>
				<div class="swiper-plates w-auto overflow-hidden rounded-2xl">
					<ul id="plate-nav" class="px-3 py-3 swiper-wrapper">
						{
							plates.map((plate) => (
								<li class="swiper-slide !w-auto last:mr-4">
									<a
										href={`#${plate.data.slug}`}
										data-category-link={plate.data.slug}
										data-category-pill
										class="inline-flex rounded-full px-4 py-2 text-sm font-medium tracking-wide text-garage-gold-bright/90 select-none whitespace-nowrap"
									>
										{plate.data.prettyName}
									</a>
								</li>
							))
						}
					</ul>
				</div>
			</nav>
		</div>

		<div class="flex flex-col gap-16 lg:gap-20">
			{
				plates.map((plate, i) => (
					<section
						id={plate.data.slug}
						class="scroll-mt-[calc(var(--site-header-h)+1rem)]"
						data-category-section={plate.data.slug}
					>
						<div
							class="relative overflow-hidden rounded-2xl border border-garage-gold/25 bg-gradient-to-br from-garage-panel/95 via-[#161616] to-garage-panel/85 p-6 sm:p-8 shadow-[inset_0_1px_0_rgba(240,215,140,0.1),0_12px_40px_rgba(0,0,0,0.2)]"
						>
							<div
								class="pointer-events-none absolute -right-12 -top-12 size-56 rounded-full bg-garage-gold/[0.08] blur-3xl"
								aria-hidden="true"
							/>
							<header class="relative mb-8 sm:mb-10 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 border-b border-garage-gold/25 pb-6">
								<div>
									<p class="font-mono text-xs tabular-nums text-garage-gold-muted mb-2">
										{String(i + 1).padStart(2, "0")} / {String(plates.length).padStart(2, "0")}
									</p>
									<h2 class="font-garage text-2xl sm:text-3xl text-garage-gold-bright tracking-wide">
										{plate.data.prettyName}
									</h2>
									<p class="mt-2 max-w-md text-sm sm:text-base text-[#e0d4c4]/88 leading-relaxed">
										{plate.data.description}
									</p>
								</div>
							</header>

							<ul class="relative grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 list-none p-0 m-0">
								{plate.data.plates.map((item: CollectionEntry<"plates">["data"]["plates"][number]) => (
									<li class="group h-full">
										<div class="h-full rounded-xl border border-garage-gold/25 bg-garage-panel/45 px-4 py-3.5 sm:px-5 sm:py-4 transition-all duration-300 hover:border-garage-gold/35 hover:bg-garage-panel/70 hover:shadow-[0_0_0_1px_rgba(212,175,55,0.1)]">
											<div class="flex items-end gap-3">
												<div class="min-w-0 flex-1 flex items-baseline gap-2">
													<span class="font-garage text-base sm:text-[1.05rem] text-[#f0e8dc] group-hover:text-garage-gold-bright transition-colors">
														{item.name}
													</span>
													<span
														class="flex-1 border-b border-dotted border-garage-gold/35 min-w-[0.75rem] mb-1.5 opacity-70"
														aria-hidden="true"
													/>
												</div>
												<span class="shrink-0 font-semibold tabular-nums text-garage-gold-bright text-sm sm:text-base">
													{new Intl.NumberFormat(siteLangFormat, {
														style: "currency",
														currency: siteCurrency,
													}).format(item.price)}
												</span>
											</div>
											{item.description ? (
												<p class="mt-2.5 text-xs sm:text-[0.8125rem] text-[#d8ccb8]/95 leading-relaxed">
													{item.description}
												</p>
											) : null}
										</div>
									</li>
								))}
							</ul>
						</div>
					</section>
				))
			}
		</div>
	</div>
</div>

<style>
	@media screen and (min-width: 0px) and (max-width: 1023px) {
		#plate-nav-wrapper {
			margin-left: calc(-1 * (100vw - 100%) / 2);
			margin-right: calc(-1 * (100vw - 100%) / 2);
			width: 100vw;
			max-width: 100vw;
			padding-left: max(1rem, env(safe-area-inset-left));
			padding-right: max(1rem, env(safe-area-inset-right));
		}
	}
</style>

<span class="hidden bg-garage-gold text-garage-black hover:bg-garage-gold/15 border-garage-gold bg-garage-gold/10 text-garage-gold-bright" aria-hidden="true"></span>

<script>
	import Swiper from "swiper";
	import "swiper/css";

	document.addEventListener("astro:page-load", () => {
		const swiperPlates = document.querySelector(".swiper-plates") as HTMLElement | null;
		let swiper: InstanceType<typeof Swiper> | null = null;
		if (swiperPlates) {
			swiper = new Swiper(swiperPlates, {
				loop: false,
				spaceBetween: 12,
				slidesPerView: "auto",
			});
		}

		const categoryLinks = document.querySelectorAll("[data-category-link]");
		const categorySections = document.querySelectorAll("[data-category-section]");
		let isNavigatingByClick = false;

		function clearActive() {
			categoryLinks.forEach((link) => {
				link.classList.remove("bg-garage-gold", "text-garage-black");
				link.classList.remove("border-garage-gold", "bg-garage-gold/10", "text-garage-gold-bright");
				link.classList.remove("hover:bg-garage-gold/15");
				if (link.hasAttribute("data-category-pill")) {
					link.classList.add("hover:bg-garage-gold/15");
				}
				if (link.hasAttribute("data-category-rail")) {
					link.classList.add("border-transparent", "text-garage-gold-muted");
				}
			});
		}

		function setActiveCategory(id: string) {
			clearActive();

			document.querySelectorAll(`[data-category-link="${id}"]`).forEach((currentLink) => {
				if (currentLink.hasAttribute("data-category-pill")) {
					currentLink.classList.remove("hover:bg-garage-gold/15");
					currentLink.classList.add("bg-garage-gold", "text-garage-black");
				}
				if (currentLink.hasAttribute("data-category-rail")) {
					currentLink.classList.remove("border-transparent", "text-garage-gold-muted");
					currentLink.classList.add("border-garage-gold", "bg-garage-gold/10", "text-garage-gold-bright");
				}
			});

			if (swiper) {
				const first = document.querySelector(`[data-category-link="${id}"][data-category-pill]`);
				if (first) {
					const linkIndex = Array.from(
						document.querySelectorAll("[data-category-pill]"),
					).indexOf(first as Element);
					if (linkIndex !== -1) {
						swiper.slideTo(linkIndex);
					}
				}
			}
		}

		categoryLinks.forEach((link) => {
			if (link.hasAttribute("data-category-pill")) {
				link.classList.add("hover:bg-garage-gold/15");
			}
		});

		categoryLinks.forEach((link) => {
			link.addEventListener("click", () => {
				const targetId = (link as HTMLElement).dataset.categoryLink;
				if (targetId) {
					isNavigatingByClick = true;
					setActiveCategory(targetId);
					setTimeout(() => {
						isNavigatingByClick = false;
					}, 1000);
				}
			});
		});

		const observer = new IntersectionObserver(
			(entries) => {
				if (isNavigatingByClick) return;

				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						const sectionId = (entry.target as HTMLElement).dataset.categorySection;
						if (sectionId) {
							setActiveCategory(sectionId);
						}
					}
				});
			},
			{ rootMargin: "-18% 0px -58% 0px", threshold: 0 },
		);

		categorySections.forEach((section) => {
			observer.observe(section);
		});

		const setInitialActiveCategory = () => {
			if (window.location.hash) {
				const id = window.location.hash.substring(1);
				setActiveCategory(id);
			} else if (categorySections.length > 0) {
				const firstSectionId = (categorySections[0] as HTMLElement).dataset.categorySection;
				if (firstSectionId) {
					setActiveCategory(firstSectionId);
				}
			}
		};

		setInitialActiveCategory();
	});
</script>
