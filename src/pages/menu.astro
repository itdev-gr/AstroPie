---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import MenuList from "~/components/Menu.astro";
import { seoMenu } from "~/data/seo";
---

<Layout title={seoMenu.ogTitle} pageTitle={seoMenu.pageTitle} description={seoMenu.description}>
	<Section class:list={"garage-section menu-light"} innerClass="!pt-8 lg:!pt-10 !pb-20 lg:!pb-28">
		<header class="max-w-6xl mx-auto mb-12 lg:mb-16 flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 border-b border-garage-gold/25 pb-8">
			<div>
				<p class="font-garage text-[0.65rem] tracking-[0.35em] text-garage-gold-muted uppercase mb-3">Garage Cafe</p>
				<h1 class="font-garage text-4xl sm:text-5xl lg:text-6xl text-garage-gold-bright uppercase tracking-[0.08em] drop-shadow-sm">
					Menu
				</h1>
			</div>
			<p class="text-[#e0d4c4]/90 text-sm sm:text-base max-w-sm lg:text-right leading-relaxed">
				Served all day · Prices as in store
			</p>
		</header>

		<MenuList />
	</Section>
</Layout>
