---
import { menuMain } from "~/data/menus.js";

const rmTrailingSlash = (path: string): string => {
	return path.endsWith("/") && path.length > 1 ? path.slice(0, path.length - 1) : path;
};

const pathname = rmTrailingSlash(Astro.url.pathname);
---

<header
	class="site-header fixed inset-x-0 top-0 z-50 border-b border-garage-gold/15 bg-transparent"
	x-data="{ open: false }"
	x-effect="document.body.style.overflow = open ? 'hidden' : ''"
	@keydown.window.escape="open = false"
>
	<div
		class="container pb-4 pt-[max(1rem,env(safe-area-inset-top))] sm:pb-5 sm:pt-[max(1.25rem,env(safe-area-inset-top))]"
	>
		<nav class="flex items-center justify-between drop-shadow-[0_2px_14px_rgba(0,0,0,0.9)]" aria-label="Main navigation">
			<a
				href="/"
				class="flex items-center -m-1.5 p-1.5 rounded-full ring-1 ring-transparent hover:ring-garage-gold/30 transition-[box-shadow]"
				aria-label="Garage Cafe — Home"
			>
				<img
					src="/images/garage/logo.png"
					alt="Garage Cafe Rhodes — Coffee and more"
					width="112"
					height="112"
					class="rounded-full ring-1 ring-garage-gold/40 size-20 sm:size-24 md:size-28 object-cover"
				/>
			</a>
			<div class="flex lg:hidden">
				<button
					type="button"
					class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-garage-gold-bright hover:text-garage-gold"
					@click="open = true"
				>
					<span class="sr-only">Open menu</span>
					<svg
						class="size-8"
						fill="none"
						viewBox="0 0 24 24"
						stroke-width="1.5"
						stroke="currentColor"
						aria-hidden="true"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
					</svg>
				</button>
			</div>
			<div class="hidden lg:flex lg:gap-x-10 lg:items-center">
				{
					menuMain.map((item) => (
						<a
							href={item.url}
							class={`transition text-[18px] font-medium tracking-wide uppercase text-garage-gold-bright/90 hover:text-garage-gold-bright ${item.highlighted ? "menu-item-highlighted" : ""} ${pathname === item.url ? "menu-item-active" : ""}`}
						>
							{item.name}
						</a>
					))
				}
			</div>
		</nav>
	</div>

	<!-- Full-screen mobile menu (outside .container so fixed covers the viewport) -->
	<div class="lg:hidden" x-ref="dialog" x-show="open" x-cloak>
		<div
			role="dialog"
			aria-modal="true"
			aria-label="Site menu"
			class="fixed inset-0 z-[200] flex h-[100dvh] max-h-[100dvh] w-screen max-w-[100vw] flex-col bg-garage-black overscroll-contain"
			style="padding-top: env(safe-area-inset-top, 0px); padding-bottom: env(safe-area-inset-bottom, 0px);"
			x-show="open"
			x-transition:enter="transition ease-out duration-200"
			x-transition:enter-start="opacity-0"
			x-transition:enter-end="opacity-100"
			x-transition:leave="transition ease-in duration-150"
			x-transition:leave-start="opacity-100"
			x-transition:leave-end="opacity-0"
			x-cloak
		>
			<div class="flex h-full min-h-0 flex-1 flex-col px-6 pt-4 pb-6 sm:px-8">
				<div class="flex shrink-0 items-center justify-between gap-4 border-b border-garage-gold/15 pb-4">
					<a
						href="/"
						class="flex items-center -m-1.5 p-1.5"
						@click="open = false"
						aria-label="Garage Cafe — Home"
					>
						<img
							src="/images/garage/logo.png"
							alt="Garage Cafe Rhodes — Coffee and more"
							width="104"
							height="104"
							class="rounded-full ring-1 ring-garage-gold/40 size-16 object-cover sm:size-[88px]"
						/>
					</a>
					<button
						type="button"
						class="flex size-12 items-center justify-center rounded-full border border-garage-gold/30 text-garage-gold-bright hover:bg-garage-gold/10"
						@click="open = false"
					>
						<span class="sr-only">Close menu</span>
						<svg
							class="size-7"
							fill="none"
							viewBox="0 0 24 24"
							stroke-width="2"
							stroke="currentColor"
							aria-hidden="true"
						>
							<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
						</svg>
					</button>
				</div>
				<nav class="flex flex-1 flex-col justify-center gap-1 py-8" aria-label="Main navigation">
					{
						menuMain.map((item) => (
							<a
								@click="open = false"
								href={item.url}
								class={`block py-4 text-center font-garage text-2xl tracking-widest uppercase text-garage-gold-bright border-b border-garage-gold/10 last:border-0 sm:text-3xl ${item.highlighted ? "menu-item-highlighted w-max mx-auto !px-10 !py-3 !my-2" : ""} ${pathname === item.url ? "menu-item-active" : ""}`}
							>
								{item.name}
							</a>
						))
					}
				</nav>
			</div>
		</div>
	</div>
</header>
